# OpenClaw Gateway WebSocket URL
GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw home directory（Pi 上需显式设置，填写实际绝对路径）
# OPENCLAW_HOME=/path/to/.openclaw

# open-workhorse 本地鉴权 token（必须设置一个随机值）
# 生成方式：openssl rand -hex 24
LOCAL_API_TOKEN=
LOCAL_TOKEN_AUTH_REQUIRED=true

# 安全默认值 — 首次接入保持不变
READONLY_MODE=true
APPROVAL_ACTIONS_ENABLED=false
APPROVAL_ACTIONS_DRY_RUN=true
IMPORT_MUTATION_ENABLED=false
IMPORT_MUTATION_DRY_RUN=false

# UI 服务
UI_MODE=false
UI_PORT=4310

# Telegram HITL 通知（可选 — 用于 PR 合并决策与停滞告警）
# 配置步骤见 scripts/telegram.sh 文件头部注释
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 开发周期停滞检测阈值（小时，默认 4）
DEV_WATCHDOG_STALE_HOURS=4

# Pandas 编排层 — 共享收件箱根目录
# 默认：~/Dev/everything_openclaw/personas/shared-resources
# Pi 上需显式设置绝对路径（避免 ~ 展开问题）
# SHARED_RESOURCES_ROOT=/path/to/shared-resources

# GitHub 仓库路径（owner/repo），用于构造 PR URL（如 tg_pr_ready 通知）
# 若未设置则自动从 git remote origin 推断
# GITHUB_REPO=rushwing/open-workhorse

# Pandas 心跳间隔（分钟，1–60，默认 30）
# 紧急任务通过 Telegram "start REQ-N" 直接触发，无需缩短此间隔
# PANDAS_HEARTBEAT_INTERVAL_MINUTES=30

# Agent 命名（harness.sh 认领 prompt 中使用；默认值见注释）
# 修改此处后重启 harness.sh 即生效，无需改动脚本本身
AGENT_ORCHESTRATOR=pandas    # 编排、确认、回归监控
AGENT_CODER=menglan          # 实现代码、修 bug
AGENT_REVIEWER=huahua        # 需求评审、code review

# Proxy — set if claude -p in cron needs to go through a proxy to reach the Anthropic API
# http_proxy=http://proxy-host:port
# https_proxy=http://proxy-host:port
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port
